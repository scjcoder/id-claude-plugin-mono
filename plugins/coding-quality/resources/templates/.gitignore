# .gitignore — canonical template
# Author:       Sean Johnson <sean@scj.net>
# Purpose:      Baseline .gitignore for Python + Terraform projects
# Last updated: 2026-05-30
# Version:      1.0.0
#
# Usage: copy to your project root, adjust as needed

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.venv/
venv/
ENV/
env/

# Environment variables (NEVER commit secrets)
.env
.env.local
.env.*.local
*.env

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.hypothesis/

# Terraform
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!example.tfvars
override.tf
override.tf.json
*_override.tf
*_override.tf.json
crash.log

# Node (if applicable)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build artifacts
*.log
*.bak
*.tmp
